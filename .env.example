# ============================================================
# ProductionList — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# -----------------------------------------------------------
# Supabase (required)
# Get these from: https://app.supabase.com → Project Settings → API
# -----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------
# Site
# -----------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://productionlist.com

# -----------------------------------------------------------
# Stripe (for membership payments)
# -----------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs — create these in your Stripe dashboard
# Map to PMPro levels:
# Level 1 = Annual Pro Plan ($467.40/year)
STRIPE_PRICE_ANNUAL_PRO=price_...
# Level 2 = 6-Month Unlimited ($293.70)
STRIPE_PRICE_6MONTH=price_...
# Level 3 = Monthly Unlimited ($58.95/month)
STRIPE_PRICE_MONTHLY=price_...
# Level 4 = 1-Month Trial ($29.95 first, then $58.95)
STRIPE_PRICE_TRIAL_MONTHLY=price_...
# Level 5 = 50% Off Annual ($233.70/year)
STRIPE_PRICE_ANNUAL_HALF=price_...
# Level 6 = 14-Day Free Trial
STRIPE_PRICE_14DAY_TRIAL=price_...
# Level 7 = 14-Day Free Trial (alt)
STRIPE_PRICE_14DAY_TRIAL_2=price_...

# -----------------------------------------------------------
# Email (Resend — for transactional emails)
# -----------------------------------------------------------
RESEND_API_KEY=re_...

# Resend Audience IDs
RESEND_AUDIENCE_ID=your-general-audience-id
RESEND_AUDIENCE_MEMBERS_ID=your-members-audience-id
RESEND_AUDIENCE_PAST_MEMBERS_ID=your-past-members-audience-id

EMAIL_FROM=noreply@productionlist.com

# -----------------------------------------------------------
# Migration (only needed when running scripts/migration/)
# -----------------------------------------------------------
# Local MySQL connection — used by migration scripts only
MYSQL_HOST=127.0.0.1
MYSQL_PORT=10033
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=local
MYSQL_SOCKET=/Users/greysomething/Library/Application Support/Local/run/2W0rfPpDJ/mysql/mysqld.sock

# -----------------------------------------------------------
# Media
# -----------------------------------------------------------
# Where WP uploads were hosted (for migration remapping)
WP_UPLOADS_BASE_URL=https://productionlist.com/wp-content/uploads
# After migration, Supabase Storage bucket name
SUPABASE_STORAGE_BUCKET=media
